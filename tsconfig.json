{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true
  },
  "include": [
    "App.tsx",
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "DesignSystemSpec/docs",
    "DesignSystemSpec/lib",
    "DesignSystemSpec/pages",
    "DesignSystemSpec/styles",
    "dist",
    ".expo"
  ]
}
