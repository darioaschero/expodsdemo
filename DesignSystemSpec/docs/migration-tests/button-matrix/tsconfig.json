    "../../../build/components/button.ts",
    "../../../build/components/icon-button.ts",
    "../../../build/components/switch.ts",
    "../../../build/components/tabs.ts",
    "../../../build/components/tab-bar.ts",
    "../../../build/components/list.ts",
    "../../../build/components/list-item.ts",
    "../../../build/components/list-interactive-item.ts"
  ]
}
